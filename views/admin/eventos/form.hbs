<h2>{{title}}</h2>
<div class='row mt-3'>
  <div class='col-md-6'>
    <form method='POST' action='{{action}}' enctype='multipart/form-data'>
      <div class='mb-3'>
        <label for='nome' class='form-label'>
          Nome do evento
          <span class='text-danger'>*</span>
        </label>
        <input
          type='text'
          class='form-control'
          name='nome'
          id='nome'
          value='{{evento.nome}}'
          required
        />
      </div>
      <div class='mb-3'>
        <label for='codigo_base' class='form-label'>
          Código base (3 letras)
          <span class='text-danger'>*</span>
        </label>
        <input
          type='text'
          class='form-control'
          name='codigo_base'
          id='codigo_base'
          value='{{evento.codigo_base}}'
          required
          pattern='[A-Za-z]{3}'
          maxlength='3'
          title='Exatamente 3 letras sem números ou símbolos'
        />
      </div>
      <div class='mb-3'>
        <label for='ano' class='form-label'>
          Ano
          <span class='text-danger'>*</span>
        </label>
        <input
          type='number'
          class='form-control'
          name='ano'
          id='ano'
          value='{{evento.ano}}'
          required
          min='2000'
          max='2100'
        />
      </div>
      <div class='mb-3'>
        <label for='template_base' class='form-label'>
          Template base do certificado
          <small class='text-muted'>(PNG ou JPG, máx. 2 MB)</small>
        </label>
        {{#if evento.url_template_base}}
          <div class='mb-1 text-muted small'>
            Atual:
            <code>{{evento.url_template_base}}</code>
          </div>
        {{/if}}
        <input
          type='file'
          class='form-control'
          name='template_base'
          id='template_base'
          accept='.png,.jpg,.jpeg,image/png,image/jpeg'
        />
        <div class='form-text'>Deixe em branco para manter o template atual.</div>
      </div>

      <h5 class='mt-4'>Posição do texto-base no certificado</h5>
      <div class='row mb-3'>
        <div class='col-md-6'>
          <label for='texto_x' class='form-label'>X (horizontal)</label>
          <input
            type='number'
            class='form-control'
            name='texto_x'
            id='texto_x'
            value='{{evento.texto_x}}'
            min='0'
            placeholder='Ex.: 270'
          />
        </div>
        <div class='col-md-6'>
          <label for='texto_y' class='form-label'>Y (vertical)</label>
          <input
            type='number'
            class='form-control'
            name='texto_y'
            id='texto_y'
            value='{{evento.texto_y}}'
            min='0'
            placeholder='Ex.: 200'
          />
        </div>
      </div>

      <h5 class='mt-2'>Posição da validação no certificado</h5>
      <div class='row mb-3'>
        <div class='col-md-6'>
          <label for='validacao_x' class='form-label'>X (horizontal)</label>
          <input
            type='number'
            class='form-control'
            name='validacao_x'
            id='validacao_x'
            value='{{evento.validacao_x}}'
            min='0'
            placeholder='Ex.: 145'
          />
        </div>
        <div class='col-md-6'>
          <label for='validacao_y' class='form-label'>Y (vertical)</label>
          <input
            type='number'
            class='form-control'
            name='validacao_y'
            id='validacao_y'
            value='{{evento.validacao_y}}'
            min='0'
            placeholder='Ex.: 545'
          />
        </div>
      </div>

      <button type='submit' class='btn btn-primary'>Salvar</button>
      <a href='/admin/eventos' class='btn btn-secondary ms-2'>Cancelar</a>
    </form>
  </div>
</div>